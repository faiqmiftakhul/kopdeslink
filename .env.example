# === KopdesLink — contoh environment (SALIN ke .env.local, ISI nilainya) ===
# JANGAN commit .env.local ke repo publik.

# Sumber data:
#   mock = jalan tanpa DB (data contoh, cocok untuk dev/backup demo)
#   db   = BACA data nyata dari Postgres bersama hackathon (read-only),
#          lalu operasi tulis (POS/request/transfer) berjalan di memori app.
DATA_SOURCE=db

# Kredensial Postgres bersama — ISI dari gcloud_database.txt (JANGAN commit .env.local)
DB_HOST=
DB_PORT=5432
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
# WAJIB true — server DB menolak koneksi tanpa enkripsi (pg_hba: no encryption).
DB_SSL=true

# Prefix tabel milik tim (dipakai bila suatu saat punya DB yang bisa ditulis).
# Catatan: kredensial panitia READ-ONLY (tak bisa CREATE), jadi mode `db`
# tidak menulis apa pun ke DB bersama.
TABLE_PREFIX=indonesiacerah_

# Kecamatan/kabupaten fokus demo (prefix kode_wilayah dari referensi_wilayah).
# Contoh siap-demo: 53.71 = Kota Kupang, NTT (7 Kopdes, Beras SPHP surplus vs butuh).
# Kosongkan untuk memuat sampai 500 Kopdes berkoordinat (matchmaking lintas wilayah).
FOCUS_KODE_WILAYAH=53.71

# Radius pencarian Kopdes tetangga (km). Kupang: jarak maks antar-Kopdes 8,3 km.
MATCH_RADIUS_KM=15
